# Copia este archivo como .env y completa los valores reales
# NUNCA subas el archivo .env real a GitHub

# Conexión a Supabase (PostgreSQL)
DATABASE_URL=postgresql://usuario:contraseña@host:puerto/nombre_base_datos

# OpenAI — obtén tu clave en https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Contraseña de acceso a la interfaz web Streamlit
APP_PASSWORD=tu_contraseña_segura
